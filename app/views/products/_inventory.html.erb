<% app/views/products/_inventory.html.erb %>
<% if product.inventory_count.positive? %>
  <p><%= if product.inventory_count %> in stock </p>
<% else %>
  <p>Out of stock</p>
  <Email me when available.</p>

  <%= form_with model: [product, Subscriber.new] do |form| %>
    <%= form.email_field :email, placeholder: "you@example.com", require: true %>
    <% form.submit "Submit" %>
  <% end %>
<% end %>
  
